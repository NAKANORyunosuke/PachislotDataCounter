# Pachislot Data Counter — 環境設定テンプレート
#
# このファイルを .env にコピーして値を埋める(.env は .gitignore 済み):
#   cp host/.env.example host/.env
#
# 読み込まれ方:
#   - systemd 経由: pachislot-data-counter.service が EnvironmentFile で読む
#   - 開発起動:     run.sh が起動時に読む
# どちらも "KEY=value" 形式・1行1項目・= の前後に空白を入れないこと.

# Cloudflare Tunnel 等で外部公開する際の https ホスト名(末尾スラッシュ無し).
# 登録 / 表示設定フォームの QR コードの URL 生成に使う.
# 未設定ならリクエスト元のホスト名から組み立てる.
PUBLIC_BASE_URL=https://pachislot.example.com

# Pico をつなぐシリアルポート / ボーレート(未設定なら下記が既定値).
#SERIAL_PORT=/dev/ttyACM0
#SERIAL_BAUD=115200
